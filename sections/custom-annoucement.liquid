{% comment %}
  Custom Announcement Bar - Continuous Marquee Version
{% endcomment %}

{% if section.settings.show_announcement %}
  {% if section.settings.homepage_only == false or request.page_type == 'index' %}

    <section id="custom-announcement-{{ section.id }}" class="custom-announcement-bar">

      <div class="marquee">
        <div class="marquee__content">

          {% for block in section.blocks %}
            <span class="marquee__item">
              {% if block.settings.message_link != blank %}
                <a href="{{ block.settings.message_link }}">
                  {{ block.settings.message }}
                </a>
              {% else %}
                {{ block.settings.message }}
              {% endif %}
            </span>
          {% endfor %}

          <!-- Duplicate for infinite scroll -->
          {% for block in section.blocks %}
            <span class="marquee__item">
              {% if block.settings.message_link != blank %}
                <a href="{{ block.settings.message_link }}">
                  {{ block.settings.message }}
                </a>
              {% else %}
                {{ block.settings.message }}
              {% endif %}
            </span>
          {% endfor %}

        </div>
      </div>

      {% if section.settings.show_close %}
        <div class="announcement-close" onclick="this.parentElement.remove()">
          ✕
        </div>
      {% endif %}

    </section>

  {% endif %}
{% endif %}

<style>
.custom-announcement-bar {
  position: relative;
  overflow: hidden;
  background: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
  padding: 10px 0;
  font-size: 14px;
  font-weight: 500;
}

/* Marquee Container */
.marquee {
  width: 100%;
  overflow: hidden;
}

/* Moving Content */
.marquee__content {
  display: flex;
  width: max-content;
  animation: scroll-marquee linear infinite;
  animation-duration: {{ section.settings.speed }}s;
}

/* Each Item */
.marquee__item {
  white-space: nowrap;
  margin-right: 60px;
}

/* Links */
.marquee__item a {
  color: inherit;
  text-decoration: none;
}

/* Hover Pause */
.marquee:hover .marquee__content {
  animation-play-state: paused;
}

/* Animation */
@keyframes scroll-marquee {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* Close Button */
.announcement-close {
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  cursor: pointer;
  font-size: 16px;
}

/* Gradient Fade Effect (Premium) */
.custom-announcement-bar::before,
.custom-announcement-bar::after {
  content: "";
  position: absolute;
  top: 0;
  width: 60px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.custom-announcement-bar::before {
  left: 0;
  background: linear-gradient(to right, {{ section.settings.bg_color }}, transparent);
}

.custom-announcement-bar::after {
  right: 0;
  background: linear-gradient(to left, {{ section.settings.bg_color }}, transparent);
}
</style>

{% schema %}
{
  "name": "Marquee Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "homepage_only",
      "label": "Show only on homepage",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close button",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#c4553c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds)",
      "min": 10,
      "max": 40,
      "step": 2,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "message",
          "label": "Message",
          "default": "Free shipping on all orders 🚚"
        },
        {
          "type": "url",
          "id": "message_link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Announcement Bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}