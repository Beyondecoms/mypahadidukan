              <div class="contact_details__1IFAQ">
                <strong>Write to Us</strong
                ><br><a href="mailto:{{section.settings.email}}" class="contact_mail-link__1ML5W"
                  >{{section.settings.email}}</a
                >
              </div>
            </li>
            <li style="border-bottom:1px solid rgba(0, 0, 0, 0.2)">
              <div class="contact_pic__2q4Zs"><img src="https://cdn.shopify.com/s/files/1/0746/0952/5042/files/contact_mail.png?v=1756193998"></div>
              <div class="contact_details__1IFAQ">
                <div class="contact_address__1XL_T">
                  <strong>Mailing Address</strong>
                  {{section.settings.mailaddress}}
                </div>
              </div>
            </li>
            <li>
              <div>
                <strong>Working Hours:</strong>
                <p class="contact_contact-time-text__3EhVW">
                  {{section.settings.workinghr}}
                </p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
      .contexxtbtn {
          display: block;
          padding-left: 0;
          padding-right: 0;
          width: 326px;
          margin: 0 auto;
      }
      .contact-faq-wrapper {
          align-items: flex-start;
          max-width: 1140px !important;
          margin: 0 auto !important;
          display: -webkit-flex;
          display: -moz-box;
          display: flex;
          -webkit-flex-wrap: wrap;
          flex-wrap: wrap;
          padding-left: 0;
          padding-right: 0;
      }
    .contact-left {
      display: block;
      padding: 70px 15px 0;
      -webkit-flex: 0 0 50%;
      -moz-box-flex: 0;
      flex: 0 0 50%;
      max-width: 50%;
  }
  .faq-right:before {
      position: absolute;
      content: "";
      left: 0;
      top: 0;
      height: 100%;
      width: 75vw;
      background: #f9f9f9;
      z-index: -1;
      border-left: 1px solid rgba(0, 0, 0, .2);
  }
    .contact-left h2{
      font-size:28px;
      margin-bottom:10px;
      color: #c0503b;
    }
    .faqheader h2 {
    
    color: #c0503b;
}
    .contact-left p{margin-bottom:15px;}
    .chat-btn{display:inline-flex;align-items:center;gap:8px;background:#ceae95;color:#fff;padding:10px 20px;border-radius:5px;text-decoration:none;}
    .chat-btn:hover{background:#ceae95;}

    .faq-right {
      -webkit-flex: 0 0 50%;
      -moz-box-flex: 0;
      flex: 0 0 50%;
      max-width: 50%;
      position: relative;
      z-index: 1;
      padding-left: 60px;
      padding-bottom: 90px;
      padding-top: 30px;
      
  }
    .faq-tabs{display:flex;gap:10px;margin-bottom:15px;overflow-x:auto;}
    .tab-btn {
      padding: 5px 10px;
      border: 1px solid #ceae95;
      background: none;
      border-radius: 12px;
      cursor: pointer;
      white-space: nowrap;
      font-size: 14px;
      font-weight: 700;
  }
    .tab-btn.active{background:#ceae95;color:#fff;}
    .faq-contents {
      background: #FFF3F1;
  }
    .faq-tab-content{display:none;}
    .faq-tab-content.active{display:block;}

    .accordion {
      border: 1px solid #ceae95;
      border-radius: 0;
      border-bottom: 0;
  }
  .accordion:last-child {
      border: 1px solid #ceae95;
  }
    .accordion-header{width:100%;text-align:left;padding:10px;border:none;cursor:pointer;font-weight:bold;}
    .accordion-body {
      display: none;
      padding: 10px;
      color: #000;
  }
  button.accordion-header {
      border: 0 !important;
  }
    .accordion.open .accordion-body{display:block;}
    section.contact-faq-section {
      background: #fcfbf9;
  }
  .faqheader {
      text-align: center;
      padding-bottom: 20px;
  }
  .faqheader h2 {
      font-size: 28px;
  }
  ul.contact_contact-ul__2FGUL li {
    padding: 40px 0;
    display: -webkit-flex;
    display: -moz-box;
    display: flex;
    -webkit-align-items: start;
    -moz-box-align: start;
    align-items: start;
    gap: 10px;
}
.contact_pic__2q4Zs {
    min-width: 80px;
    text-align: center;
}
ul.contact_contact-ul__2FGUL strong {
    font-weight: 600;
    font-size: 20px;
    color: #000;
}
@media (max-width: 767px) {
    .contact_main-contact-section-details__-S7r- {
        position: relative;
    }
}
@media (max-width: 767px) {
    .contact-left,
    .faq-right {
        -webkit-flex: 0 0 100%;
        -moz-box-flex: 0;
        flex: 0 0 100%;
        max-width: 100%;
        padding: 30px 15px 30px;
    }
    .faq-right:before{
        width: 100%;
        border-left: 0;
    }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Tab switch
    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
        document.querySelectorAll('.faq-tab-content').forEach((tc) => tc.classList.remove('active'));
        this.classList.add('active');
        document.getElementById(this.dataset.tab).classList.add('active');
      });
    });

    // Accordion toggle
    document.querySelectorAll('.accordion-header').forEach((header) => {
      header.addEventListener('click', function () {
        let acc = this.parentElement;
        acc.classList.toggle('open');
        let body = acc.querySelector('.accordion-body');
        body.style.display = acc.classList.contains('open') ? 'block' : 'none';
      });
    });
  });
</script>

{% schema %}
{
  "name": "Contact & FAQ",
  "settings": [
    { "type": "text", "id": "left_title", "label": "Left Title", "default": "Contact Us" },
    {
      "type": "textarea",
      "id": "left_text",
      "label": "Left Description",
      "default": "If you’re here, you either love us or we screwed up."
    },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Chat with Us" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "text", "id": "right_title", "label": "Right Title", "default": "FAQs" },
    {
      "type": "text",
      "id": "right_subtitle",
      "label": "Right Subtitle",
      "default": "Find answers to common questions."
    },
    {
        "type": "text",
        "id": "email",
        "label": "Email"
      },
      {
          "type": "richtext",
          "id": "mailaddress",
          "label": "Email Address"
        },
        {
            "type": "text",
            "id": "workinghr",
            "label": "Working Hour"
          }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "FAQ Tab",
      "settings": [{ "type": "text", "id": "tab_title", "label": "Tab Title", "default": "Orders and Shipping" }]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "parent_tab", "label": "Parent Tab Title (Exactly same as Tab Title)" },
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "Contact & FAQ", "category": "Custom" }]
}
{% endschema %}
