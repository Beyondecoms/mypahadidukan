<section class="contact-faq-section">
  <div class="container">
    <div class="contact-faq-wrapper">
      <!-- LEFT SIDE -->
      <div class="contact-left">
        <div class="contexxtbtn">
          <h2>{{ section.settings.left_title }}</h2>
          <p>{{ section.settings.left_text }}</p>
          <a href="{{ section.settings.button_link }}" class="chat-btn">
            <img
              src="https://cdn.shopify.com/s/files/1/0746/0952/5042/files/whatsapp-2.svg?v=1756193758"
              alt="whatsapp icon"
            >
            {{- section.settings.button_text }}
          </a>
        </div>
      </div>

      <!-- RIGHT SIDE -->
      <div class="faq-right">
        <div class="faqheader">
          <h2>{{ section.settings.right_title }}</h2>
          <p>{{ section.settings.right_subtitle }}</p>
        </div>
        <!-- Tabs -->
        <div class="faq-tabs">
          {% assign first_tab = '' %}
          {% for block in section.blocks %}
            {% if block.type == 'tab' %}
              {% if first_tab == '' %}{% assign first_tab = block.settings.tab_title %}{% endif %}
              <button
                class="tab-btn {% if block.settings.tab_title == first_tab %}active{% endif %}"
                data-tab="{{ block.settings.tab_title | handleize }}"
              >
                {{ block.settings.tab_title }}
              </button>
            {% endif %}
          {% endfor %}
        </div>

        <!-- Tab Content -->
        <div class="faq-contents">
          {% for block in section.blocks %}
            {% if block.type == 'tab' %}
              <div
                class="faq-tab-content {% if block.settings.tab_title == first_tab %}active{% endif %}"
                id="{{ block.settings.tab_title | handleize }}"
              >
                {% assign i = 0 %}
                {% for faq in section.blocks %}
                  {% if faq.type == 'faq' and faq.settings.parent_tab == block.settings.tab_title %}
                    {% assign i = i | plus: 1 %}
                    <div class="accordion {% if i == 1 %}open{% endif %}">
                      <button class="accordion-header">{{ faq.settings.question }}</button>
                      <div
                        class="accordion-body"
                        {% if i == 1 %}
                          style="display:block;"
                        {% endif %}
                      >
                        {{ faq.settings.answer }}
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="faqfooter">
          <ul class="contact_contact-ul__2FGUL">
            <li style="border-bottom:1px solid rgba(0, 0, 0, 0.2)">
              <div class="contact_pic__2q4Zs">
                <svg
                                 width="54"
                                 height="42"
                                 viewBox="0 0 54 42"
                                 fill="none"
                                 xmlns="http://www.w3.org/2000/svg"
                               >
