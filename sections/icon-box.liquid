{{ 'icon-box.css' | asset_url | stylesheet_tag }}
<script src="{{ 'icon-box.js' | asset_url }}" defer="defer"></script>

<style> 

{% if section.settings.enable_scroller %}
#m-section--{{ section.id }} .shop-region__grid{
  display:flex;
  flex-wrap:nowrap;
  overflow-x:auto;
  overflow-y:hidden;
  gap:0px;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  padding-bottom:10px;
}

#m-section--{{ section.id }} .shop-region__grid::-webkit-scrollbar{
  height:6px;
}

#m-section--{{ section.id }} .shop-region__grid::-webkit-scrollbar-thumb{
  background:#c7b299;
  border-radius:20px;
}

#m-section--{{ section.id }} .shop-region__column{
  flex:0 0 16%;
  scroll-snap-align:start;
}

@media(max-width:768px){
  #m-section--{{ section.id }} .shop-region__column{
    flex:0 0 30%;
  }
  .shop-region__card{
    height: 50% !important;
  padding: 0 !important;
  }
  .shop-region__grid{
    gap: 8px !important;
  }
  .shop-region__card{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  }
  .m-icon-box__icon{
    width: 120px !important;
    
  }
}
{% endif %}
</style>


{% liquid
  assign enable_slider = section.settings.enable_slider
  assign use_scroll_mobile = section.settings.use_scroll_mobile

  assign blocks = section.blocks
  assign card_style = section.settings.card_style
  assign card_classes = 'm:flex-col shop-region__card-inner'
  assign alignment = 'sm:m:items-' | append: section.settings.content_alignment
  assign text_alignment = 'sm:m:text-' | append: section.settings.content_alignment | replace: 'start', 'left' | replace: 'end', 'right'
  assign icon_classes = 'm:items-start shop-region__media-wrap'

  if card_style == 'horizontal'
    assign card_classes = 'm:flex-row m:flex-nowrap shop-region__card-inner shop-region__card-inner--horizontal'
    if enable_slider or use_scroll_mobile
      assign alignment = 'm:items-' | append: section.settings.content_alignment
      assign text_alignment = 'm:text-' | append: section.settings.content_alignment | replace: 'start', 'left' | replace: 'end', 'right'
    else
      assign text_alignment = 'm:text-left sm:m:text-' | append: section.settings.content_alignment | replace: 'start', 'left' | replace: 'end', 'right'
      assign icon_classes = 'm:items-start shop-region__media-wrap'
      assign alignment = ''
    endif
  else
    if enable_slider or use_scroll_mobile
      assign icon_classes = 'm:items-' | append: section.settings.content_alignment
      assign alignment = 'm:items-' | append: section.settings.content_alignment
      assign text_alignment = 'm:text-' | append: section.settings.content_alignment | replace: 'start', 'left' | replace: 'end', 'right'
    else
      assign text_alignment = 'm:text-' | append: section.settings.content_alignment | replace: 'start', 'left' | replace: 'end', 'right'
      assign icon_classes = 'm:items-' | append: section.settings.content_alignment
      assign alignment = 'm:items-' | append: section.settings.content_alignment
    endif
  endif

  assign hover = 'm-hover-box shop-region__hover'
  case section.settings.hover_effect
    when 'scaling-down'
      assign hover = hover | append: ' m-hover-box--scale-down'
    when 'scaling-up'
      assign hover = hover | append: ' m-hover-box--scale-up'
    when 'zoom-in'
      assign hover = hover | append: ' m-hover-box--zoom-in'
    else
      assign hover = ''
  endcase

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign icon_box_classes = ''
  if enable_slider == false and use_scroll_mobile == false and section.settings.use_grid_column_mb == false
    assign icon_box_classes = ' m-icon-box--col-1'
  endif

  assign container_width = settings.container_width
  assign container_fluid_width = settings.container_fluid_width
  assign classes = 'm-section m-icon-box-section shop-region'
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme
%}

{% if section.settings.enable_slider %}
  {%- style -%}
    {% if section.settings.container == 'container' %}
      @media (max-width: {{ container_width | plus: 189 }}px) {
        #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-prev { left: 0; }
        #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-next { right: 0; }
      }
    {% elsif section.settings.container == 'container-fluid' %}
      @media (max-width: {{ container_fluid_width | plus: 189 }}px) {
        #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-prev { left: 0; }
        #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-next { right: 0; }
      }
    {% else %}
      #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-prev { left: 0; }
      #m-section--{{ section.id }} .m-slider-controls--absolute .m-slider-controls__button-next { right: 0; }
    {% endif %}
  {%- endstyle -%}
{% endif %}

<style>
  #m-section--{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --column-gap: {{ section.settings.item_gap }}px;
    --column-gap-mobile: {{ section.settings.item_gap_mobile }}px;
    --row-gap: {{ section.settings.item_gap | plus: 10 }}px;
    --row-gap-mobile: 22px;
    --items: {{ section.settings.item_per_row }};
  }

  #m-section--{{ section.id }}.shop-region {
    position: relative;
    overflow: hidden;
  }

  #m-section--{{ section.id }} .shop-region__shell {
    position: relative;
    padding-top: 8px;
  }

  #m-section--{{ section.id }} .shop-region__shell::before {
    content: "";
    position: absolute;
    inset: -30px auto auto 50%;
    width: 360px;
    height: 360px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0) 68%);
    pointer-events: none;
  }

  #m-section--{{ section.id }} .shop-region__header {
    margin-bottom: 28px;
  }

  #m-section--{{ section.id }} .shop-region__header .m-section-header,
  #m-section--{{ section.id }} .shop-region__header .section-header {
    text-align: center;
  }

  #m-section--{{ section.id }} .shop-region__wrapper {
    position: relative;
    z-index: 1;
  }

  #m-section--{{ section.id }} .shop-region__grid {
    position: relative;
    z-index: 1;
  }

  #m-section--{{ section.id }} .shop-region__column {
    height: auto;
  }

  #m-section--{{ section.id }} .shop-region__card {
    height: 100%;
    border-radius: 26px;
    padding: 0px;
    {% comment %} background: rgba(255, 248, 235, 0.82);
    border: 1px solid rgba(135, 95, 56, 0.14);
    box-shadow: 0 10px 30px rgba(81, 52, 23, 0.08); {% endcomment %}
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
    backdrop-filter: blur(6px);
  }

  #m-section--{{ section.id }} .shop-region__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 42px rgba(81, 52, 23, 0.14);
    border-color: rgba(135, 95, 56, 0.22);
  }

  #m-section--{{ section.id }} .shop-region__card-inner {
    gap: 14px;
    align-items: center;
  }

  #m-section--{{ section.id }} .shop-region__media-wrap {
    width: 100%;
    max-width: {{ section.settings.image_max_width | default: '100%' }};
    margin-inline: auto;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(255,255,255,0.36), rgba(255,255,255,0.08));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.5);
  }

  #m-section--{{ section.id }} .shop-region__media-wrap img,
  #m-section--{{ section.id }} .shop-region__media-wrap .m-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 22px;
    transform: scale(1);
    transition: transform 0.35s ease;
  }

  #m-section--{{ section.id }} .shop-region__card:hover .shop-region__media-wrap img,
  #m-section--{{ section.id }} .shop-region__card:hover .shop-region__media-wrap .m-image {
    transform: scale(1.05);
  }

  #m-section--{{ section.id }} .shop-region__content {
    padding: 4px 4px 2px;
  }

  #m-section--{{ section.id }} .shop-region__title {
    margin: 0 0 8px;
    font-size: clamp(1rem, 0.95rem + 0.4vw, 1.15rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: rgba(67, 39, 16, 0.96);
  }

  #m-section--{{ section.id }} .shop-region__description {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(89, 63, 36, 0.84);
  }

  #m-section--{{ section.id }} .shop-region__button {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
  }

  #m-section--{{ section.id }} .shop-region__button:hover {
    transform: translateY(-1px);
  }

  #m-section--{{ section.id }} .shop-region-slider .swiper-slide {
    height: auto;
  }

  #m-section--{{ section.id }} .shop-region-slider .swiper-pagination {
    position: relative;
    margin-top: 22px;
  }

  #m-section--{{ section.id }} .shop-region-slider .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    opacity: 0.45;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  #m-section--{{ section.id }} .shop-region-slider .swiper-pagination-bullet-active {
    opacity: 1;
    transform: scale(1.25);
  }

  #m-section--{{ section.id }} .shop-region-slider .m-slider-controls__button {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  #m-section--{{ section.id }} .shop-region-slider .m-slider-controls__button:hover {
    transform: scale(1.06);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 749px) {
    #m-section--{{ section.id }} .shop-region__header {
      margin-bottom: 18px;
    }

    #m-section--{{ section.id }} .shop-region__card {
      padding: 12px;
      border-radius: 22px;
    }

    #m-section--{{ section.id }} .shop-region__card-inner {
      gap: 10px;
    }

    #m-section--{{ section.id }} .shop-region__content {
      padding: 2px 2px 0;
    }

    #m-section--{{ section.id }} .shop-region__title {
      font-size: 0.98rem;
    }

    #m-section--{{ section.id }} .shop-region__description {
      font-size: 0.88rem;
    }
  }
</style>

<section
  id="m-section--{{ section.id }}"
  class="{{ classes }}"
  data-section-type="icon-box"
  data-section-id="{{ section.id }}"
>
  <div class="{{ container }} m-section-my m-section-py shop-region__shell">
    <div class="shop-region__header">
      {% render 'index-section-header', section_settings: section.settings %}
    </div>

    <div class="shop-region-slider m-swiper-overflow m:block">
{% if enable_slider and section.settings.enable_scroller == false %}
          <div class="swiper-container shop-region-slider__container">
          <div class="swiper-wrapper shop-region__grid m:grid{% if section.settings.use_grid_column_mb %} m:grid-2-cols{% endif %} md:m:grid-2-cols lg:m:grid-{{ section.settings.item_per_row }}-cols">
            {% for block in blocks %}
              {% liquid
                assign card_color_scheme = block.settings.card_color_scheme
                if section.settings.card_color_scheme
                  assign card_color_scheme = section.settings.card_color_scheme
                endif
                assign block_classes = ' m-gradient' | append: ' m-color-' | append: card_color_scheme

                assign color_scheme_inherit = false
                if card_color_scheme == section.settings.color_scheme
                  assign color_scheme_inherit = true
                endif
              %}

              <div
                class="swiper-slide m:column shop-region__column"
                data-slide="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <div
                  class="m-icon-box m-icon-box--{{ card_style }} shop-region__card {{ icon_box_classes }} {{ block_classes }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}{% unless color_scheme_inherit %} m:blocks-radius{% else %} color-scheme-inherit{% endunless %}"
                  {% if animated %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  <div class="m-icon-box__inner {{ card_classes }} {{ alignment }}">
                    {% if block.settings.link != blank %}
                      {%- assign tag = 'a' -%}
                    {% else %}
                      {%- assign tag = 'div' -%}
                    {% endif %}

                    <{{ tag }}
                      {% if block.settings.link != blank %}
                        href="{{ block.settings.link }}"
                      {% endif %}
                      class="m-icon-box__icon {{ hover }} {{ icon_classes }}{% if color_scheme_inherit %} m:blocks-radius{% endif %}"
                      {% if section.settings.image_max_width != blank %}
                        style="width: {{ section.settings.image_max_width }};"
                      {% endif %}
                    >
                      <div class="m-hover-box__wrapper m:w-full">
                        {% if block.settings.image_by_url != blank %}
                          <img
                            src="{{ block.settings.image_by_url }}"
                            width="auto"
                            height="auto"
                            loading="lazy"
                            alt="{{ block.settings.title | escape }}"
                            class="m-icon-box__external-image m-image"
                          >
                        {% elsif block.settings.image != blank %}
                          {% render 'responsive-image',
                            image: block.settings.image,
                            wrapper_class: 'm:w-full',
                            image_class: 'm:w-full'
                          %}
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'm-placeholder-svg m-image m:w-full' }}
                        {% endif %}
                      </div>
                    </{{ tag }}>

                    <div class="m-icon-box__content shop-region__content m:flex-1 {{ text_alignment }}">
                      {% if block.settings.title != blank %}
                        <h3 class="m-icon-box__heading shop-region__title h4">{{ block.settings.title }}</h3>
                      {% endif %}

                      {% if block.settings.description != blank %}
                        <div class="m-icon-box__description shop-region__description rte m:text-color-subtext">
                          {{ block.settings.description }}
                        </div>
                      {% endif %}

                      {% if block.settings.button_label != blank %}
                        {% capture arrow %}<svg class="m-rlt-reverse-x" width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M7.03062 2.4694L12.0306 7.4694C12.1005 7.53908 12.156 7.62187 12.1939 7.71304C12.2317 7.8042 12.2512 7.90194 12.2512 8.00065C12.2512 8.09936 12.2317 8.1971 12.1939 8.28827C12.156 8.37943 12.1005 8.46222 12.0306 8.5319L7.03062 13.5319C6.88973 13.6728 6.69863 13.752 6.49937 13.752C6.30012 13.752 6.10902 13.6728 5.96812 13.5319C5.82723 13.391 5.74807 13.1999 5.74807 13.0007C5.74807 12.8014 5.82723 12.6103 5.96812 12.4694L10.4375 8.00003L5.9675 3.53065C5.8266 3.38976 5.74745 3.19866 5.74745 2.9994C5.74745 2.80015 5.8266 2.60905 5.9675 2.46815C6.10839 2.32726 6.29949 2.2481 6.49875 2.2481C6.69801 2.2481 6.8891 2.32726 7.03 2.46815L7.03062 2.4694Z" fill="currentColor"/>
                          </svg>{% endcapture %}

                        {% liquid
                          assign is_button_icon = false
                          if block.settings.button_label contains '[arrow]'
                            assign is_button_icon = true
                          endif
                        %}

                        <a
                          href="{{ block.settings.button_link | default: "#" }}"
                          class="m-button shop-region__button{% if is_button_icon %} m-button--text-with-icon{% endif %} {{ block.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' }} {{ block.settings.button_size }}"
                        >
                          {{- block.settings.button_label | replace: '[arrow]', arrow -}}
                        </a>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

        {% if enable_slider and section.settings.enable_scroller == false %}
            <div class="m-slider-controls m-slider-controls--absolute">
              {% if section.settings.show_navigation %}
                <button class="m-slider-controls__button m-slider-controls__button-prev" type="button" aria-label="Previous slide">
                  <span aria-hidden="true">‹</span>
                </button>
                <button class="m-slider-controls__button m-slider-controls__button-next" type="button" aria-label="Next slide">
                  <span aria-hidden="true">›</span>
                </button>
              {% endif %}
              {% if section.settings.show_pagination %}
                <div class="swiper-pagination"></div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="shop-region__grid {% if section.settings.enable_scroller %}shop-region__grid--scroll{% endif %} m:grid{% if section.settings.use_grid_column_mb %} m:grid-2-cols{% endif %} md:m:grid-2-cols lg:m:grid-{{ section.settings.item_per_row }}-cols">
          {% for block in blocks %}
            {% liquid
              assign card_color_scheme = block.settings.card_color_scheme
              if section.settings.card_color_scheme
                assign card_color_scheme = section.settings.card_color_scheme
              endif
              assign block_classes = ' m-gradient' | append: ' m-color-' | append: card_color_scheme

              assign color_scheme_inherit = false
              if card_color_scheme == section.settings.color_scheme
                assign color_scheme_inherit = true
              endif
            %}
            <div class="m:column shop-region__column" {{ block.shopify_attributes }}>
              <div
                class="m-icon-box m-icon-box--{{ card_style }} shop-region__card {{ icon_box_classes }} {{ block_classes }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}{% unless color_scheme_inherit %} m:blocks-radius{% else %} color-scheme-inherit{% endunless %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                <div class="m-icon-box__inner {{ card_classes }} {{ alignment }}">
                  {% if block.settings.link != blank %}
                    {%- assign tag = 'a' -%}
                  {% else %}
                    {%- assign tag = 'div' -%}
                  {% endif %}

                  <{{ tag }}
                    {% if block.settings.link != blank %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                    class="m-icon-box__icon {{ hover }} {{ icon_classes }}{% if color_scheme_inherit %} m:blocks-radius{% endif %}"
                    {% if section.settings.image_max_width != blank %}
                      style="width: {{ section.settings.image_max_width }};"
                    {% endif %}
                  >
                    <div class="m-hover-box__wrapper m:w-full">
                      {% if block.settings.image_by_url != blank %}
                        <img
                          src="{{ block.settings.image_by_url }}"
                          width="auto"
                          height="auto"
                          loading="lazy"
                          alt="{{ block.settings.title | escape }}"
                          class="m-icon-box__external-image m-image"
                        >
                      {% elsif block.settings.image != blank %}
                        {% render 'responsive-image',
                          image: block.settings.image,
                          wrapper_class: 'm:w-full',
                          image_class: 'm:w-full'
                        %}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'm-placeholder-svg m-image m:w-full' }}
                      {% endif %}
                    </div>
                  </{{ tag }}>

                  <div class="m-icon-box__content shop-region__content m:flex-1 {{ text_alignment }}">
                    {% if block.settings.title != blank %}
                      <h3 class="m-icon-box__heading shop-region__title h4">{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <div class="m-icon-box__description shop-region__description rte m:text-color-subtext">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                    {% if block.settings.button_label != blank %}
                      {% capture arrow %}<svg class="m-rlt-reverse-x" width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7.03062 2.4694L12.0306 7.4694C12.1005 7.53908 12.156 7.62187 12.1939 7.71304C12.2317 7.8042 12.2512 7.90194 12.2512 8.00065C12.2512 8.09936 12.2317 8.1971 12.1939 8.28827C12.156 8.37943 12.1005 8.46222 12.0306 8.5319L7.03062 13.5319C6.88973 13.6728 6.69863 13.752 6.49937 13.752C6.30012 13.752 6.10902 13.6728 5.96812 13.5319C5.82723 13.391 5.74807 13.1999 5.74807 13.0007C5.74807 12.8014 5.82723 12.6103 5.96812 12.4694L10.4375 8.00003L5.9675 3.53065C5.8266 3.38976 5.74745 3.19866 5.74745 2.9994C5.74745 2.80015 5.8266 2.60905 5.9675 2.46815C6.10839 2.32726 6.29949 2.2481 6.49875 2.2481C6.69801 2.2481 6.8891 2.32726 7.03 2.46815L7.03062 2.4694Z" fill="currentColor"/>
                        </svg>{% endcapture %}

                      {% liquid
                        assign is_button_icon = false
                        if block.settings.button_label contains '[arrow]'
                          assign is_button_icon = true
                        endif
                      %}

                      <a
                        href="{{ block.settings.button_link | default: "#" }}"
                        class="m-button shop-region__button{% if is_button_icon %} m-button--text-with-icon{% endif %} {{ block.settings.button_style | replace: 'sf__btn-primary', 'm-button--primary' | replace: 'sf__btn-secondary', 'm-button--secondary' | replace: 'sf__btn-link', 'm-button--link' | replace: 'sf__btn-white', 'm-button--white' }} {{ block.settings.button_size }}"
                      >
                        {{- block.settings.button_label | replace: '[arrow]', arrow -}}
                      </a>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% if section.settings.enable_slider %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const section = document.getElementById('m-section--{{ section.id }}');
  if (!section || typeof Swiper === 'undefined') return;

  const sliderEl = section.querySelector('.shop-region-slider__container');
  if (!sliderEl) return;

  const nextEl = section.querySelector('.m-slider-controls__button-next');
  const prevEl = section.querySelector('.m-slider-controls__button-prev');
  const paginationEl = section.querySelector('.swiper-pagination');

  new Swiper(sliderEl, {
    loop: true,
    speed: 800,
    spaceBetween: 18,
    grabCursor: true,
    watchOverflow: true,
    autoplay: {
      delay: 2500,
      disableOnInteraction: false,
      pauseOnMouseEnter: true
    },
    pagination: paginationEl
      ? {
          el: paginationEl,
          clickable: true
        }
      : undefined,
    navigation: nextEl && prevEl
      ? {
          nextEl,
          prevEl
        }
      : undefined,
    breakpoints: {
      0: {
        slidesPerView: 1.15,
        spaceBetween: 12
      },
      640: {
        slidesPerView: 2,
        spaceBetween: 14
      },
      990: {
        slidesPerView: 4,
        spaceBetween: 18
      },
      1200: {
        slidesPerView: Math.min({{ section.settings.item_per_row }}, 6),
        spaceBetween: 20
      }
    }
  });
});
</script>
{% endif %}

