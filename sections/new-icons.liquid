<div id="icons-grid-{{ section.id }}" class="icons-grid-section">
  <div class="icons-grid-container {% if section.settings.enable_slider %}swiper-container{% endif %}">
    <div class="{% if section.settings.enable_slider %}swiper-wrapper{% else %}icons-wrapper{% endif %}">
      {% for block in section.blocks %}
        <div class="{% if section.settings.enable_slider %}swiper-slide{% else %}icon-item{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.icon_link != blank %}
            <a href="{{ block.settings.icon_link }}">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.icon_text | escape }}">
              {% endif %}
            </a>
          {% else %}
            {% if block.settings.icon_image != blank %}
              <img src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.icon_text | escape }}">
            {% endif %}
          {% endif %}
          {% if block.settings.icon_text != blank %}
            <div class="icon-text">{{ block.settings.icon_text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.enable_slider %}
      <!-- Navigation Arrows -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>

      <!-- Pagination Dots -->
      <div class="swiper-pagination"></div>
    {% endif %}
  </div>
</div>

{% style %}
#icons-grid-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  max-width: {{ section.settings.container_width }}%;
  margin: 0 auto;
  padding: 20px 0;
}

/* Default Grid */
#icons-grid-{{ section.id }} .icons-wrapper {
  display: grid;
  grid-template-columns: repeat({{ section.settings.icons_per_row_desktop }}, 1fr);
  gap: {{ section.settings.gap_between_icons }}px;
  justify-items: center;
  align-items: center;
}

#icons-grid-{{ section.id }} .icon-item img {
  max-width: {{ section.settings.image_width_desktop }}px;
  height: auto;
  display: block;
  margin: 0 auto;
}

#icons-grid-{{ section.id }} .icon-text {
  margin-top: 8px;
  font-size: 14px;
  text-align: center;
}

/* Mobile Styling */
@media (max-width: 768px) {
  #icons-grid-{{ section.id }} .icons-wrapper {
    grid-template-columns: repeat({{ section.settings.icons_per_row_mobile }}, 1fr);
  }

  #icons-grid-{{ section.id }} .icon-item img {
    max-width: {{ section.settings.image_width_mobile }}px;
  }
}

/* Swiper Specific Styling */
{% if section.settings.enable_slider %}
#icons-grid-{{ section.id }} .swiper-container {
  width: 100%;
}

#icons-grid-{{ section.id }} .swiper-wrapper {
  display: flex;
  gap: {{ section.settings.gap_between_icons }}px;
}

#icons-grid-{{ section.id }} .swiper-slide {
  width: auto;
  text-align: center;
}
{% endif %}
{% endstyle %}

{% if section.settings.enable_slider %}
<script>
document.addEventListener("DOMContentLoaded", function () {
    new Swiper("#icons-grid-{{ section.id }} .swiper-container", {
      slidesPerView: {{ section.settings.icons_per_row_desktop }},
      spaceBetween: {{ section.settings.gap_between_icons }},
      loop: false,
      navigation: {
        nextEl: "#icons-grid-{{ section.id }} .swiper-button-next",
        prevEl: "#icons-grid-{{ section.id }} .swiper-button-prev",
      },
      pagination: {
        el: "#icons-grid-{{ section.id }} .swiper-pagination",
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: {{ section.settings.icons_per_row_mobile }},
          spaceBetween: {{ section.settings.gap_between_icons }}
        }
      }
    });
});
</script>
{% endif %}

{% schema %}
{
  "name": "Icons Grid with Slider",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width (%)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 100
    },
    {
      "type": "range",
      "id": "gap_between_icons",
      "label": "Gap Between Icons (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "icons_per_row_desktop",
      "label": "Icons per row (Desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "icons_per_row_mobile",
      "label": "Icons per row (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Icon Width Desktop (px)",
      "min": 20,
      "max": 300,
      "step": 5,
      "default": 120
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Icon Width Mobile (px)",
      "min": 20,
      "max": 300,
      "step": 5,
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Text Below Icon",
          "default": "Your Icon Text"
        },
        {
          "type": "url",
          "id": "icon_link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icons Grid with Slider",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
