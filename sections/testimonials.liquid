<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">

{%- style -%}
.mpd-testimonials {
  padding: 20px 0 60px;
  position: relative;
}

/* Big decorative quote mark */
.mpd-testimonials::before {
  content: '\201C';
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 180px;
  line-height: 1;
  color: #c8462e;
  opacity: 0.08;
  font-family: Georgia, serif;
  pointer-events: none;
  z-index: 0;
}

/* Splide track */
.mpd-testimonials .splide__track {
  overflow: visible;
  padding: 20px 0 30px !important;
}

/* Card */
.mpd-tcard {
  background: #fff;
  border-radius: 20px;
  padding: 36px 32px 28px;
  border: 1px solid #f0e8e0;
  position: relative;
  transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  transform: scale(0.94);
  opacity: 0.5;
  filter: blur(1px);
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 24px;
}

.splide__slide.is-active .mpd-tcard {
  transform: scale(1);
  opacity: 1;
  filter: none;
  border-color: #e8d5c4;
  box-shadow: 0 8px 48px rgba(200, 70, 46, 0.10), 0 2px 12px rgba(0,0,0,0.06);
}

/* Stars */
.mpd-tcard__stars {
  display: flex;
  gap: 3px;
  margin-bottom: 14px;
}
.mpd-tcard__stars svg {
  width: 16px;
  height: 16px;
  fill: #c8462e;
}

/* Quote mark small */
.mpd-tcard__quote-icon {
  width: 32px;
  height: 32px;
  background: #fdf0ea;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  flex-shrink: 0;
}
.mpd-tcard__quote-icon svg {
  width: 16px;
  height: 16px;
  fill: #c8462e;
}

/* Title */
.mpd-tcard__title {
  font-size: 17px;
  font-weight: 700;
  color: #1a0e08;
  margin: 0 0 10px;
  line-height: 1.3;
}

/* Body */
.mpd-tcard__body {
  font-size: 14px;
  line-height: 1.75;
  color: #5a4035;
  margin: 0;
  flex: 1;
}

/* Footer — author + product */
.mpd-tcard__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding-top: 20px;
  border-top: 1px solid #f5ece6;
  margin-top: auto;
}

/* Author */
.mpd-tcard__author {
  display: flex;
  align-items: center;
  gap: 10px;
}
.mpd-tcard__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #fdf0ea;
  border: 2px solid #e8c5b0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  color: #c8462e;
  flex-shrink: 0;
  text-transform: uppercase;
}
.mpd-tcard__name {
  font-size: 13px;
  font-weight: 600;
  color: #1a0e08;
  margin: 0;
}
.mpd-tcard__verified {
  font-size: 11px;
  color: #3a9e8a;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 3px;
  margin-top: 1px;
}
.mpd-tcard__verified svg {
  width: 11px;
  height: 11px;
  fill: #3a9e8a;
}

/* Product pill */
.mpd-tcard__product {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f9f4f0;
  border: 1px solid #ecddd4;
  border-radius: 40px;
  padding: 4px 12px 4px 4px;
  text-decoration: none;
  transition: background 0.2s ease;
  max-width: 180px;
  overflow: hidden;
}
.mpd-tcard__product:hover {
  background: #f5ebe0;
}
.mpd-tcard__product-img {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}
.mpd-tcard__product-name {
  font-size: 11px;
  color: #5a3020;
  font-weight: 600;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Navigation */
.mpd-testimonials__nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 32px;
}
.mpd-nav-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1.5px solid #e0cec4;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  color: #c8462e;
}
.mpd-nav-btn:hover {
  background: #c8462e;
  border-color: #c8462e;
  color: #fff;
  transform: scale(1.08);
}
.mpd-nav-btn svg {
  width: 18px;
  height: 18px;
  stroke: currentColor;
  fill: none;
}

/* Fraction counter */
.mpd-counter {
  font-size: 13px;
  color: #9b7b5e;
  font-weight: 500;
  min-width: 48px;
  text-align: center;
  letter-spacing: 0.04em;
}
.mpd-counter strong {
  color: #c8462e;
  font-weight: 700;
}

/* Progress bar */
.mpd-progress {
  width: 80px;
  height: 3px;
  background: #f0e4dc;
  border-radius: 2px;
  overflow: hidden;
  position: relative;
}
.mpd-progress__fill {
  height: 100%;
  background: #c8462e;
  border-radius: 2px;
  transition: width 0.5s ease;
}

@media (max-width: 768px) {
  .mpd-tcard {
    padding: 28px 22px 22px;
    transform: scale(1) !important;
    opacity: 1 !important;
    filter: none !important;
  }
  .mpd-tcard__product {
    display: none;
  }
}
.t-heading{
  text-align: center;
  color:#c0503b;
}
{%- endstyle -%}

{%- liquid
  assign total_blocks = section.blocks.size
-%}


<div class="mpd-testimonials" id="mpd-testimonials-{{ section.id }}">

  <h3 class="t-heading">TESTIMONIALS</h3>
  <div class="splide" id="mpd-splide-{{ section.id }}" aria-label="Customer Testimonials">
    <div class="splide__track">
      <ul class="splide__list">
        {% for block in section.blocks %}
          {%- liquid
            assign author_raw = block.settings.footer | strip_html | strip
            assign author_name = author_raw | split: '.' | first | strip
            if author_name == blank
              assign author_name = 'Customer'
            endif
            assign avatar_letter = author_name | slice: 0 | upcase
            assign product = block.settings.product
          -%}
          <li class="splide__slide" {{ block.shopify_attributes }}>
            <div class="mpd-tcard">
              <div>
                <!-- Stars -->
                {% if section.settings.show_stars %}
                  <div class="mpd-tcard__stars">
                    {% for i in (1..5) %}
                      <svg viewBox="0 0 16 15" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 1.46327L9.90277 5.31871L10.0191 5.55443L10.2792 5.59223L14.534 6.21048L11.4552 9.21152L11.267 9.395L11.3114 9.65409L12.0382 13.8916L8.23267 11.8909L8 11.7686L7.76733 11.8909L3.96178 13.8916L4.68858 9.65409L4.73301 9.395L4.54478 9.21152L1.46603 6.21048L5.72076 5.59223L5.98089 5.55443L6.09723 5.31871L8 1.46327Z"/>
                      </svg>
                    {% endfor %}
                  </div>
                {% endif %}

                <!-- Quote icon -->
                <div class="mpd-tcard__quote-icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
                  </svg>
                </div>

                <!-- Title + description -->
                {% if block.settings.title != blank %}
                  <h3 class="mpd-tcard__title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="mpd-tcard__body">{{ block.settings.description | strip_html }}</p>
                {% endif %}
              </div>

              <!-- Footer: author + product -->
              <div class="mpd-tcard__footer">
                <div class="mpd-tcard__author">
                  <div class="mpd-tcard__avatar">{{ avatar_letter }}</div>
                  <div>
                    <p class="mpd-tcard__name">{{ author_name }}</p>
                    <div class="mpd-tcard__verified">
                      <svg viewBox="0 0 12 12" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 0L7.5 2.2 10.2 1.8 10.6 4.5 13 5.5 11.8 8 13 10.5 10.6 11.5 10.2 14.2 7.5 13.8 6 16 4.5 13.8 1.8 14.2 1.4 11.5 -1 10.5 0.2 8 -1 5.5 1.4 4.5 1.8 1.8 4.5 2.2z" transform="scale(0.75)"/>
                      </svg>
                      Verified buyer
                    </div>
                  </div>
                </div>

                {% if product != blank %}
                  <a href="{{ product.url }}" class="mpd-tcard__product" target="_blank" aria-label="{{ product.title }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}"
                        alt="{{ product.title }}"
                        class="mpd-tcard__product-img"
                        loading="lazy"
                        width="32"
                        height="32"
                      >
                    {% endif %}
                    <span class="mpd-tcard__product-name">{{ product.title | truncate: 28 }}</span>
                  </a>
                {% endif %}
              </div>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- Custom nav -->
  <div class="mpd-testimonials__nav">
    <button class="mpd-nav-btn" id="mpd-prev-{{ section.id }}" aria-label="Previous">
      <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="mpd-progress">
      <div class="mpd-progress__fill" id="mpd-progress-{{ section.id }}" style="width: {{ 1 | divided_by: total_blocks | times: 100 }}%"></div>
    </div>

    <span class="mpd-counter" id="mpd-counter-{{ section.id }}">
      <strong>1</strong> / {{ total_blocks }}
    </span>

    <div class="mpd-progress">
      <div class="mpd-progress__fill" style="width: 100%"></div>
    </div>

    <button class="mpd-nav-btn" id="mpd-next-{{ section.id }}" aria-label="Next">
      <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var el = document.querySelector('#mpd-splide-{{ section.id }}');
  if (!el || typeof Splide === 'undefined') return;

  var total = {{ total_blocks }};
  var counter = document.getElementById('mpd-counter-{{ section.id }}');
  var progress = document.getElementById('mpd-progress-{{ section.id }}');

  var splide = new Splide('#mpd-splide-{{ section.id }}', {
    type: 'loop',
    perPage: 2,
    perMove: 1,
    gap: '24px',
    arrows: false,
    pagination: false,
    focus: 'center',
    speed: 600,
    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)',
    breakpoints: {
      768: { perPage: 1, gap: '16px' }
    }
  });

  splide.on('moved', function(newIndex) {
    var display = newIndex + 1;
    if (counter) {
      counter.innerHTML = '<strong>' + display + '</strong> / ' + total;
    }
    if (progress) {
      progress.style.width = (display / total * 100) + '%';
    }
  });

  splide.mount();

  var prevBtn = document.getElementById('mpd-prev-{{ section.id }}');
  var nextBtn = document.getElementById('mpd-next-{{ section.id }}');
  if (prevBtn) prevBtn.addEventListener('click', function() { splide.go('<'); });
  if (nextBtn) nextBtn.addEventListener('click', function() { splide.go('>'); });
});
</script>

