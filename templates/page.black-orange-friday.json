{"sections":{"main":{"type":"page","disabled":true,"custom_css":[],"settings":{}},"custom_liquid_w8fdVz":{"type":"custom-liquid","name":"Custom liquid","settings":{"custom_liquid":"<style>\n#MainContent {\n  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);\n}\n.bf-header h2 {\n  font-size: 1.8rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.black-outline {\n  color: black;\n  -webkit-text-stroke: 1px white; \/* black outline *\/\n  text-stroke: 1px black;\n  font-weight: 700;\n}\n\n.hyphen {\n  color: white;\n  font-weight: 700;\n}\n\n.highlight {\n  color: #ff6b35; \/* Orange *\/\n  font-weight: 700;\n}\n\n\n\/* MOBILE FIRST *\/\n.bf-section {\n  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);\n  padding: 2rem 0;\n  overflow: hidden;\n}\n\n.bf-header {\n  text-align: center;\n  margin-bottom: 1.5rem;\n  padding: 0 1rem;\n}\n\n.bf-header h2 {\n  color: #fff;\n  font-size: 1.8rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.bf-header .highlight {\n  color: #ff6b35;\n}\n\n.bf-header p {\n  color: #c7c7c7;\n  font-size: 1rem;\n}\n\n.products-wrapper {\n  position: relative;\n  padding: 0 1rem;\n}\n\n.products-carousel {\n  display: flex;\n  gap: 1rem;\n  overflow-x: auto;\n  scroll-behavior: smooth;\n  padding: 0.5rem 0 1.5rem;\n  scrollbar-width: thin;\n  scrollbar-color: #ff6b35 #2d2d2d;\n}\n\n.products-carousel::-webkit-scrollbar {\n  height: 6px;\n}\n\n.products-carousel::-webkit-scrollbar-track {\n  background: #2d2d2d;\n  border-radius: 10px;\n}\n\n.products-carousel::-webkit-scrollbar-thumb {\n  background: #ff6b35;\n  border-radius: 10px;\n}\n\n.scroll-btn {\n  display: none; \/* hidden on mobile *\/\n}\n\n.product-card {\n  background: #fff;\n  border-radius: 16px;\n  min-width: 260px;\n  max-width: 260px;\n  height: 550px; \/* increased height *\/\n  flex-shrink: 0;\n  overflow: hidden;\n  box-shadow: 0 8px 24px rgba(0,0,0,0.3);\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  position: relative;\n  display: flex;\n  flex-direction: column;\n}\n\n.product-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 10px 28px rgba(255, 107, 53, 0.35);\n}\n\n.discount-badge {\n  position: absolute;\n  top: 12px;\n  right: 12px;\n  background: #ff6b35;\n  color: #fff;\n  padding: 8px 14px;\n  border-radius: 25px;\n  font-weight: 700;\n  font-size: 0.9rem;\n  z-index: 5;\n  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.5);\n  animation: pulse 2s infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { transform: scale(1); }\n  50% { transform: scale(1.05); }\n}\n\n\/* 4:3 IMAGE AREA WITHOUT SQUISHING *\/\n.product-image-wrapper {\n  position: relative;\n  width: 100%;\n  height: 220px; \/* Adjust to your desired image area height *\/\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: #fff; \/* Ensures white space around image *\/\n  overflow: hidden;\n}\n\n.product-image-wrapper img {\n  max-width: 100%;   \/* Image fits inside wrapper, leaves padding *\/\n  max-height: 100%;  \/* Image fits inside wrapper, leaves padding *\/\n  object-fit: cover; \/* Ensures full image is visible *\/\n  margin: auto;\n  display: block;\n  background: transparent;\n  transition: transform 0.4s ease;\n}\n\n.product-card:hover .product-image-wrapper img {\n  transform: scale(1.08);\n}\n\n\/* FLEX CONTENT: TEXT + FORM *\/\n.product-content {\n  padding: 1rem 1rem 0.9rem;\n  display: flex;\n  flex-direction: column;\n  flex: 1 1 auto;\n}\n\n.product-title {\n  color: #2d2d2d;\n  font-size: 1rem;\n  font-weight: 600;\n  margin-bottom: 0.6rem;\n  line-height: 1.4;\n  height: 2.8em;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n}\n\n.price-section {\n  margin-bottom: 0.5rem;\n}\n\n.price-row {\n  display: flex;\n  align-items: center;\n  gap: 0.6rem;\n  margin-bottom: 0.3rem;\n}\n\n.current-price {\n  color: #ff6b35;\n  font-size: 1.6rem;\n  font-weight: 800;\n  line-height: 1;\n}\n\n.original-price {\n  color: #999;\n  font-size: 1.1rem;\n  text-decoration: line-through;\n  font-weight: 500;\n}\n\n.savings-text {\n  color: #00aa5b;\n  font-size: 0.85rem;\n  font-weight: 600;\n}\n\n.stock-status {\n  font-size: 0.8rem;\n  margin-bottom: 0.4rem;\n  font-weight: 600;\n}\n\n.stock-status.in-stock {\n  color: #00aa5b;\n}\n\n.stock-status.low-stock {\n  color: #ff9500;\n}\n\n.stock-status.out-of-stock {\n  color: #ff3b30;\n}\n\n\/* FORM STICKS TO BOTTOM AREA *\/\n.product-form {\n  display: flex;\n  flex-direction: column;\n  gap: 0.6rem;\n  margin-top: auto;\n}\n\n\/* VARIANTS AS DROPDOWN INSTEAD OF TILES *\/\n.variant-selector {\n  display: flex;\n  flex-direction: column;\n  gap: 0.3rem;\n}\n\n.variant-label {\n  font-size: 0.8rem;\n  color: #666;\n  font-weight: 600;\n}\n\n.variant-select {\n  width: 100%;\n  padding: 0.45rem 2.2rem 0.45rem 0.6rem; \/* extra right-padding for arrow *\/\n  border-radius: 8px;\n  border: 1px solid #ddd;\n  font-size: 0.85rem;\n  color: #333;\n  background: #fff;\n  appearance: none;\n  -webkit-appearance: none;\n  -moz-appearance: none;\n  background-image: url('data:image\/svg+xml;utf8,<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M6 9l6 6 6-6\" fill=\"none\" stroke=\"%23666\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/><\/svg>');\n  background-repeat: no-repeat;\n  background-position: right 10px center;\n  background-size: 14px;\n}\n\n\n\/* QUANTITY *\/\n.quantity-selector {\n  display: flex;\n  align-items: center;\n  gap: 0.4rem;\n}\n\n.quantity-label {\n  font-size: 0.8rem;\n  color: #666;\n  font-weight: 600;\n}\n\n.quantity-controls {\n  display: flex;\n  border: 2px solid #ddd;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.qty-btn {\n  background: #f5f5f5;\n  border: none;\n  width: 30px;\n  height: 30px;\n  cursor: pointer;\n  font-size: 1.1rem;\n  color: #333;\n  transition: all 0.2s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.qty-btn:hover {\n  background: #ff6b35;\n  color: #fff;\n}\n\n.qty-input {\n  border: none;\n  width: 45px;\n  text-align: center;\n  font-size: 0.95rem;\n  font-weight: 600;\n  border-left: 1px solid #ddd;\n  border-right: 1px solid #ddd;\n  background: #fff;\n}\n\n\/* ONLY ADD TO CART BUTTON *\/\n.add-to-cart-btn {\n  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);\n  color: #fff;\n  border: none;\n  padding: 0.8rem;\n  border-radius: 10px;\n  font-size: 0.95rem;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  box-shadow: 0 3px 12px rgba(255, 107, 53, 0.4);\n  width: 100%;\n}\n\n.add-to-cart-btn:hover {\n  transform: translateY(-1px);\n  box-shadow: 0 5px 16px rgba(255, 107, 53, 0.6);\n}\n\n\/* DESKTOP ENHANCEMENTS *\/\n@media (min-width: 768px) {\n  .bf-section {\n    padding: 3rem 0;\n  }\n\n  .bf-header h2 {\n    font-size: 2.2rem;\n  }\n\n  .products-wrapper {\n    padding: 0 60px;\n  }\n\n  .products-carousel {\n    gap: 1.5rem;\n    padding: 1rem 1rem 2rem;\n  }\n\n  .scroll-btn {\n    display: flex;\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    background: rgba(255, 107, 53, 0.9);\n    color: #fff;\n    border: none;\n    width: 40px;\n    height: 40px;\n    border-radius: 50%;\n    cursor: pointer;\n    z-index: 10;\n    transition: all 0.3s ease;\n    align-items: center;\n    justify-content: center;\n    font-size: 1.2rem;\n  }\n\n  .scroll-btn.left {\n    left: 10px;\n  }\n\n  .scroll-btn.right {\n    right: 10px;\n  }\n\n  .product-card {\n    min-width: 300px;\n    max-width: 300px;\n    height: 560px; \/* a bit taller on desktop *\/\n  }\n}\n.subtitle {\n  color: #c7c7c7;\n  font-size: 1rem;\n  margin-top: 0.3rem;\n  font-style: italic;\n}\n\n.countdown {\n  color: #ff6b35;\n  font-size: 1.1rem;\n  font-weight: 700;\n  margin-top: 0.6rem;\n  font-family: monospace;\n}\n\n<\/style>\n\n<div class=\"bf-section\">\n  <div class=\"bf-header\">\n  <h2><span class=\"highlight\">Orange<\/span><span class=\"hyphen\">-<\/span><span class=\"black-outline\">Black<\/span> Friday Deals\n  <\/h2>\n  <p class=\"subtitle\">Nature’s strongest duo, now at Orange-Black Friday prices!<\/p>\n  <div id=\"countdown\" class=\"countdown\"><\/div>\n<\/div>\n\n\n  <div class=\"products-wrapper\">\n    <button class=\"scroll-btn left\" onclick=\"scrollCarousel('left')\">‹<\/button>\n    <button class=\"scroll-btn right\" onclick=\"scrollCarousel('right')\">›<\/button>\n    \n    <div class=\"products-carousel\" id=\"productsCarousel\">\n      {% for product in collections['black-friday'].products %}\n        <div class=\"product-card\">\n          {% if product.compare_at_price > product.price %}\n            {% assign discount_amount = product.compare_at_price | minus: product.price %}\n            {% assign discount_percent = discount_amount | times: 100 | divided_by: product.compare_at_price %}\n            <div class=\"discount-badge\">{{ discount_percent }}% OFF<\/div>\n          {% endif %}\n\n          <div class=\"product-image-wrapper\">\n            <a href=\"{{ product.url }}\">\n              {% if product.featured_image %}\n                <img \n                  src=\"{{ product.featured_image | img_url: '1200X1200', crop: 'center' }}\" \n                  alt=\"{{ product.title | escape }}\" \n                  loading=\"lazy\">\n              {% else %}\n                <img src=\"{{ 'placeholder.png' | asset_url }}\" alt=\"{{ product.title | escape }}\">\n              {% endif %}\n            <\/a>\n          <\/div>\n\n          <div class=\"product-content\">\n            <h3 class=\"product-title\">\n              <a href=\"{{ product.url }}\" style=\"color: inherit; text-decoration: none;\">\n                {{ product.title }}\n              <\/a>\n            <\/h3>\n\n            <div class=\"price-section\">\n              <div class=\"price-row\">\n                <span class=\"current-price\">{{ product.price | money | strip_html }}<\/span>\n                {% if product.compare_at_price > product.price %}\n                  <span class=\"original-price\">{{ product.compare_at_price | money | strip_html  }}<\/span>\n                {% endif %}\n              <\/div>\n              {% if product.compare_at_price > product.price %}\n                {% assign savings = product.compare_at_price | minus: product.price %}\n                <div class=\"savings-text\">Save {{ savings | money }}!<\/div>\n              {% endif %}\n            <\/div>\n\n            {% if product.available %}\n              <div class=\"stock-status in-stock\">✓ In Stock - Order Now!<\/div>\n            {% else %}\n              <div class=\"stock-status out-of-stock\">✗ Out of Stock<\/div>\n            {% endif %}\n\n            {% form 'product', product %}\n              <div class=\"product-form\">\n                {% unless product.has_only_default_variant %}\n                  <div class=\"variant-selector\">\n                    <label class=\"variant-label\">Select {{ product.options_with_values[0].name }}:<\/label>\n                    <select class=\"variant-select\" name=\"id\">\n  {% for variant in product.variants %}\n    <option \n      value=\"{{ variant.id }}\"\n      data-price=\"{{ variant.price | money }}\"\n      data-compare-at-price=\"{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}\"\n      {% if variant.id == 46659355083058 %}\n        selected\n      {% elsif variant.id != 46659355083058 and forloop.first %}\n        selected\n      {% endif %}\n      {% unless variant.available %}disabled{% endunless %}\n    >\n      {{ variant.title }}{% unless variant.available %} - Sold Out{% endunless %}\n    <\/option>\n  {% endfor %}\n<\/select>\n\n                  <\/div>\n                {% else %}\n                  <input type=\"hidden\" name=\"id\" value=\"{{ product.variants.first.id }}\">\n                {% endunless %}\n\n                <div class=\"quantity-selector\">\n                  <span class=\"quantity-label\">Qty:<\/span>\n                  <div class=\"quantity-controls\">\n                    <button type=\"button\" class=\"qty-btn\" onclick=\"decreaseQty(this)\">−<\/button>\n                    <input type=\"number\" name=\"quantity\" value=\"1\" min=\"1\" class=\"qty-input\" readonly>\n                    <button type=\"button\" class=\"qty-btn\" onclick=\"increaseQty(this)\">+<\/button>\n                  <\/div>\n                <\/div>\n\n                {% if product.available %}\n                  <button type=\"submit\" class=\"add-to-cart-btn\">\n                    🛒 Add to Cart\n                  <\/button>\n                {% else %}\n                  <button type=\"button\" class=\"add-to-cart-btn\" disabled style=\"opacity: 0.5; cursor: not-allowed;\">\n                    Out of Stock\n                  <\/button>\n                {% endif %}\n              <\/div>\n            {% endform %}\n          <\/div>\n        <\/div>\n      {% endfor %}\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nfunction scrollCarousel(direction) {\n  const carousel = document.getElementById('productsCarousel');\n  const scrollAmount = 350;\n  if (direction === 'left') {\n    carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });\n  } else {\n    carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });\n  }\n}\n\nfunction decreaseQty(button) {\n  const input = button.parentElement.querySelector('.qty-input');\n  const currentValue = parseInt(input.value);\n  if (currentValue > 1) {\n    input.value = currentValue - 1;\n  }\n}\n\nfunction increaseQty(button) {\n  const input = button.parentElement.querySelector('.qty-input');\n  const currentValue = parseInt(input.value);\n  input.value = currentValue + 1;\n}\n\nfunction startCountdownFixedEnd(elementId) {\n  const countdownElement = document.getElementById(elementId);\n  \/\/ Set fixed sale end date\/time (e.g., November 30, 2025 at 23:59:59)\n  const endTime = new Date('2025-11-30T23:59:59').getTime();\n\n  function updateCountdown() {\n    const now = new Date().getTime();\n    const distance = endTime - now;\n\n    if (distance < 0) {\n      countdownElement.textContent = \"Offer ended\";\n      clearInterval(interval);\n      return;\n    }\n\n    const days = Math.floor(distance \/ (1000 * 60 * 60 * 24));\n    const hours = Math.floor(\n      (distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60)\n    );\n    const minutes = Math.floor(\n      (distance % (1000 * 60 * 60)) \/ (1000 * 60)\n    );\n    const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\n\n    countdownElement.textContent = `Ends in ${days}d ${hours}h ${minutes}m ${seconds}s`;\n  }\n\n  updateCountdown(); \/\/ initial call\n  const interval = setInterval(updateCountdown, 1000);\n}\n\n\/\/ Start the countdown on page load\ndocument.addEventListener('DOMContentLoaded', () => {\n  startCountdownFixedEnd('countdown');\n});\ndocument.addEventListener('DOMContentLoaded', () => {\n  \/\/ Start countdown\n  startCountdownFixedEnd('countdown');\n\n  \/\/ Variant price update per card\n  document.querySelectorAll('.product-card').forEach(card => {\n    const selectEl = card.querySelector('.variant-select');\n    const currentPriceEl = card.querySelector('.current-price');\n    const originalPriceEl = card.querySelector('.original-price');\n    const savingsTextEl = card.querySelector('.savings-text');\n\n    if (!selectEl || !currentPriceEl) return;\n\n    function updateCardPrices() {\n      const selectedOption = selectEl.options[selectEl.selectedIndex];\n      const price = selectedOption.getAttribute('data-price');\n      const comparePrice = selectedOption.getAttribute('data-compare-at-price');\n\n      \/\/ Update current price\n      if (price) currentPriceEl.textContent = price;\n\n      \/\/ Update compare-at price and savings\n      if (comparePrice) {\n        if (originalPriceEl) {\n          originalPriceEl.textContent = comparePrice;\n          originalPriceEl.style.display = '';\n        }\n        if (savingsTextEl) {\n          \/\/ Optional: just show \"On sale\" if you don't want to recalc\n          savingsTextEl.textContent = 'On sale!';\n          savingsTextEl.style.display = '';\n        }\n      } else {\n        if (originalPriceEl) originalPriceEl.style.display = 'none';\n        if (savingsTextEl) savingsTextEl.style.display = 'none';\n      }\n    }\n\n    \/\/ Initial sync\n    updateCardPrices();\n\n    \/\/ Listen to changes\n    selectEl.addEventListener('change', updateCardPrices);\n  });\n});\n\nfunction cleanPriceText(priceEl) {\n  if (priceEl && priceEl.innerText.includes('<span')) {\n    priceEl.innerText = priceEl.innerText.replace(\/<span[^>]*>|<\\\/span>\/g, '').trim();\n  }\n}\n\ndocument.addEventListener('DOMContentLoaded', function() {\n  \/\/ Initial cleanup on page load\n  document.querySelectorAll('.current-price, .original-price').forEach(cleanPriceText);\n\n  \/\/ Apply to every product card's variant change\n  document.querySelectorAll('.product-card').forEach(function(card) {\n    const selectEl = card.querySelector('.variant-select');\n    const currentPriceEl = card.querySelector('.current-price');\n    const originalPriceEl = card.querySelector('.original-price');\n\n    if (selectEl) {\n      selectEl.addEventListener('change', function() {\n        \/\/ Wait for Shopify price update, then clean up\n        setTimeout(function() {\n          cleanPriceText(currentPriceEl);\n          cleanPriceText(originalPriceEl);\n        }, 10); \/\/ 10ms delay to let DOM update first\n      });\n    }\n  });\n});\n\n\n<\/script>","custom_class":""}},"featured_collection_y7KAMU":{"type":"featured-collection","disabled":true,"name":"Featured collection","settings":{"heading":"Featured collection","heading_size":"h3","subheading":"","description":"","header_alignment":"center","color_scheme":"","container":"container-fluid","collection":"black-friday","enable_flashsale":false,"show_countdown":false,"product_to_show":8,"items_per_row":4,"item_gap":30,"pcard_layout":"","pcard_image_ratio":"","show_vendor":false,"hide_title":false,"enable_slider":false,"show_pagination":false,"show_navigation":false,"show_button_on_header":false,"button_type":"link","button_text":"Shop more","button_style":"m-button--primary","button_size":"","infinite_load":false,"max_page_load":3,"mobile_disable_slider":false,"use_scroll_mobile":true,"item_gap_mobile":16,"padding_top":50,"padding_bottom":50,"custom_class":"","animations":"inherit"}},"rich_text_86geqD":{"type":"rich-text","blocks":{"text_fQ3WxN":{"type":"text","settings":{"text":"<p>Disclaimer: All sale orders might take 72 hours to dispatch.<br\/><em>No cancellations will be entertained during the sale period.<\/em><\/p>"}}},"block_order":["text_fQ3WxN"],"name":"Rich text","settings":{"container":"container","color_scheme":"dark","content_alignment":"center","padding_top":52,"padding_bottom":52,"custom_class":"","animations":"inherit"}},"1764182931d25e6303":{"type":"_blocks","blocks":{"ai_gen_block_a36ead5_LLHQAb":{"type":"ai_gen_block_a36ead5","settings":{"banner_image":"shopify:\/\/shop_images\/black_friday_sale.jpg","banner_height_desktop":500,"banner_height_mobile":150,"background_color":"#f4f4f4","show_overlay":false,"overlay_color":"#000000","overlay_opacity":0,"content_max_width":800,"text_alignment":"center","heading":"","heading_color":"#ffffff","heading_size":48,"heading_spacing":16,"subheading":"","subheading_color":"#ffffff","subheading_size":18,"button_spacing":24,"button_text":"","button_link":"","button_background":"#e84e4e","button_text_color":"#ffffff","button_background_hover":"#d43d3d","button_text_color_hover":"#ffffff","button_font_size":1