{"sections":{"main":{"type":"page","disabled":true,"settings":{}},"april_harvest_hero":{"type":"custom-liquid","name":"April Harvest Hero","settings":{"custom_liquid":"<style>\n@import url('https:\/\/fonts.googleapis.com\/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');\n\n.ah { font-family: 'Archivo', sans-serif; color: #231F20; }\n\n.ah__announce {\n  background: #048E79;\n  color: #fff;\n  text-align: center;\n  padding: 10px 20px;\n  font-size: 0.82rem;\n  font-weight: 500;\n  letter-spacing: 0.3px;\n}\n.ah__announce samp {\n  font-family: monospace;\n  font-weight: 700;\n  letter-spacing: 2px;\n  background: rgba(255,255,255,0.15);\n  padding: 1px 8px;\n  border-radius: 2px;\n}\n\n.ah__hero {\n  background: #FFEEB7;\n  padding: 80px 24px 72px;\n  text-align: center;\n  border-bottom: 1px solid rgba(35,31,32,0.1);\n}\n.ah__eyebrow {\n  font-size: 0.7rem;\n  font-weight: 600;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #F3743C;\n  margin: 0 0 20px;\n}\n.ah__hero h1 {\n  font-family: Georgia, 'Times New Roman', serif;\n  font-size: clamp(3rem, 7vw, 5.5rem);\n  font-weight: 400;\n  line-height: 1.05;\n  color: #231F20;\n  margin: 0 0 18px;\n  letter-spacing: -0.5px;\n}\n.ah__hero-desc {\n  font-size: 0.98rem;\n  color: rgba(35,31,32,0.65);\n  max-width: 500px;\n  margin: 0 auto 44px;\n  line-height: 1.75;\n  font-weight: 400;\n}\n\n.ah__countdown {\n  display: flex;\n  justify-content: center;\n  align-items: baseline;\n}\n.ah__cd-unit {\n  text-align: center;\n  padding: 0 24px;\n  border-right: 1px solid rgba(35,31,32,0.15);\n}\n.ah__cd-unit:last-child { border-right: none; }\n.ah__cd-num {\n  display: block;\n  font-size: 2.4rem;\n  font-weight: 300;\n  color: #231F20;\n  line-height: 1;\n}\n.ah__cd-lbl {\n  display: block;\n  font-size: 0.6rem;\n  letter-spacing: 2.5px;\n  text-transform: uppercase;\n  color: rgba(35,31,32,0.5);\n  margin-top: 5px;\n}\n.ah__ends {\n  font-size: 0.75rem;\n  color: rgba(35,31,32,0.5);\n  margin-top: 22px;\n  font-style: italic;\n}\n<\/style>\n\n<div class='ah'>\n  <div class='ah__announce'>\n    An extra 10% off is automatically applied at checkout.\n  <\/div>\n\n  <section class='ah__hero'>\n    <p class='ah__eyebrow'>Seasonal Offer &middot; April 2026<\/p>\n    <h1>April Re-fill Sale<\/h1>\n    <p class='ah__hero-desc'>The mountains have given their best this season. Re-fill Himalayan produce &mdash; gathered close to the source and brought straight to you.<\/p>\n\n    <div class='ah__countdown'>\n      <div class='ah__cd-unit'><span class='ah__cd-num' id='ah-d'>00<\/span><span class='ah__cd-lbl'>Days<\/span><\/div>\n      <div class='ah__cd-unit'><span class='ah__cd-num' id='ah-h'>00<\/span><span class='ah__cd-lbl'>Hours<\/span><\/div>\n      <div class='ah__cd-unit'><span class='ah__cd-num' id='ah-m'>00<\/span><span class='ah__cd-lbl'>Mins<\/span><\/div>\n      <div class='ah__cd-unit'><span class='ah__cd-num' id='ah-s'>00<\/span><span class='ah__cd-lbl'>Secs<\/span><\/div>\n    <\/div>\n    <p class='ah__ends'>Offer ends 30 April 2026<\/p>\n  <\/section>\n<\/div>\n\n<script>\n(function() {\n  var end = new Date('2026-04-30T23:59:59').getTime();\n  function pad(n) { return String(n).padStart(2,'0'); }\n  function tick() {\n    var diff = end - Date.now();\n    if (diff <= 0) { ['ah-d','ah-h','ah-m','ah-s'].forEach(function(id){ document.getElementById(id).textContent='00'; }); return; }\n    document.getElementById('ah-d').textContent = pad(Math.floor(diff\/86400000));\n    document.getElementById('ah-h').textContent = pad(Math.floor((diff%86400000)\/3600000));\n    document.getElementById('ah-m').textContent = pad(Math.floor((diff%3600000)\/60000));\n    document.getElementById('ah-s').textContent = pad(Math.floor((diff%60000)\/1000));\n  }\n  tick(); setInterval(tick,1000);\n})();\n<\/script>","custom_class":""}},"products":{"type":"featured-collection","name":"April Harvest Products","settings":{"heading":"Fresh from the Harvest","heading_size":"h3","subheading":"An extra 10% off coupon automatically appears at checkout.","description":"","header_alignment":"center","color_scheme":"","container":"container-fluid","collection":"april-re-fill","enable_flashsale":false,"show_countdown":false,"product_to_show":12,"items_per_row":4,"item_gap":30,"pcard_layout":"","pcard_image_ratio":"","show_vendor":false,"hide_title":false,"enable_slider":false,"show_pagination":false,"show_navigation":false,"show_button_on_header":false,"button_type":"load","button_text":"Load More","button_style":"m-button--primary","button_size":"","infinite_load":false,"max_page_load":3,"mobile_disable_slider":false,"use_scroll_mobile":false,"item_gap_mobile":16,"padding_top":60,"padding_bottom":60,"custom_class":"","animations":"inherit"}},"footer_note":{"type":"rich-text","blocks":{"text_note":{"type":"text","settings":{"text":"<p>Offer ends 30 April 2026. Discount is automatically applied at checkout on eligible items. Sale orders may take up to 72 hours to dispatch. No cancellations during the sale period.<\/p>"}}},"block_order":["text_note"],"settings":{"container":"container","color_scheme":"","content_alignment":"center","padding_top":40,"padding_bottom":40,"custom_class":"","animations":"inherit"}}},"order":["main","april_harvest_hero","products","footer_note"]}