stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <polyline points=\"9 18 15 12 9 6\"\/>\n    <\/svg>\n  <\/span>\n<\/a>\n\n<style>\n.mpd-vendor-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 10px 14px 10px 10px;\n  border: 1.5px solid rgba(0,0,0,0.10);\n  border-radius: 12px;\n  text-decoration: none;\n  background: #fff;\n  margin: 4px 0 12px;\n  transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;\n  max-width: 260px;\n}\n.mpd-vendor-badge:hover {\n  border-color: rgba(0,0,0,0.22);\n  box-shadow: 0 4px 14px rgba(0,0,0,0.08);\n  transform: translateY(-1px);\n}\n.mpd-vendor-icon {\n  width: 36px;\n  height: 36px;\n  background: #f4f0e8;\n  border-radius: 8px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  color: #7a6040;\n}\n.mpd-vendor-icon svg {\n  width: 17px;\n  height: 17px;\n}\n.mpd-vendor-text {\n  display: flex;\n  flex-direction: column;\n  gap: 1px;\n  flex: 1;\n}\n.mpd-vendor-eyebrow {\n  font-size: 10px;\n  font-weight: 600;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  color: #999;\n}\n.mpd-vendor-name {\n  font-size: 14px;\n  font-weight: 600;\n  color: #222;\n  line-height: 1.2;\n}\n.mpd-vendor-arrow {\n  color: #bbb;\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n  transition: color 0.18s ease, transform 0.18s ease;\n}\n.mpd-vendor-arrow svg {\n  width: 14px;\n  height: 14px;\n}\n.mpd-vendor-badge:hover .mpd-vendor-arrow {\n  color: #777;\n  transform: translateX(2px);\n}\n<\/style>"}},"custom_text_abR3zj":{"type":"custom_text","settings":{"content":"{{ product.metafields.custom.short_description | metafield_tag }}"}},"shipping_VBJFtx":{"type":"shipping","disabled":true,"settings":{"show_delivery_times":true,"deliver_text":"Estimated Delivery:","deliver_days":"7","date_format":"%b %d","show_shipping_text":false,"shipping_text":"<p><strong>Free Shipping & Returns: <\/strong>On all orders over ₹ 700<\/p>"}},"shiprocket_promise_promise_widget_htbJx8":{"type":"shopify:\/\/apps\/shiprocket-promise\/blocks\/promise_widget\/c8f3f033-bec6-4084-8d6a-4d05e2a5ba32","settings":{}},"custom_liquid_7GHiMV":{"type":"custom_liquid","name":"lab-report","settings":{"custom_liquid":"<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/pdf.js\/3.10.111\/pdf.min.js\"><\/script>\n<style>\n  #lightBoxDisplay {\n    display: none;\n    position: fixed;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    background: rgba(0, 0, 0, 0.7);\n    justify-content: center;\n    align-items: center;\n    z-index: 999;\n    padding-top: 80px;\n  }\n  #closeButton {\n    position: absolute;\n    top:80px; right: 50px;\n    cursor: pointer;\n    color: #fff;\n    font-size: 28px;\n    background: none;\n    border: none;\n    z-index: 1000;\n  }\n  #pdfViewer {\n    width: 90vw;\n    max-width: 100vw;\n    height: 85vh;\n    overflow-y: auto;\n    overflow-x: hidden;\n    background: #fff;\n    border-radius: 8px;\n    box-shadow: 0 0 40px #333;\n  }\n  .pdf-page-canvas {\n    display: block;\n    margin: 10px auto;\n    border-radius: 4px;\n    box-shadow: 0 0 7px rgba(0,0,0,0.3);\n    max-width: 100%;\n    height: auto !important;\n  }\n  .lab-button-wrap {\n    display: flex;\n    justify-content: left;\n    padding: 0;\n  }\n  #viewLabReportButton {\n    border-radius: 5px;\n    font-size: 16px;\n    text-decoration: underline;\n    cursor: pointer;\n    padding: 10px;\n    color: #000;\n    background: none;\n    border: 1px solid #ccc;\n    outline: none;\n    box-shadow: none;\n  }\n  #viewLabReportButton:focus,\n  #viewLabReportButton:active {\n    outline: none;\n    box-shadow: none;\n  }\n<\/style>\n\n<div class=\"lab-button-wrap\">\n  <button id=\"viewLabReportButton\">View Lab Report<\/button>\n<\/div>\n\n<div id=\"lightBoxDisplay\" role=\"dialog\" aria-modal=\"true\" aria-label=\"PDF Lab Report Viewer\">\n  <button id=\"closeButton\" aria-label=\"Close PDF Viewer\">&times;<\/button>\n  <div id=\"pdfViewer\"><\/div>\n<\/div>\n\n<script>\n  const pdfUrl = \"https:\/\/cdn.shopify.com\/s\/files\/1\/0746\/0952\/5042\/files\/shilajit_lab_report_january_updated_September.pdf?v=1758088368\";\n  const viewButton = document.getElementById('viewLabReportButton');\n  const lightBox = document.getElementById('lightBoxDisplay');\n  const pdfViewer = document.getElementById('pdfViewer');\n  const closeButton = document.getElementById('closeButton');\n  \n  \/\/ Set worker src for PDF.js\n  pdfjsLib.GlobalWorkerOptions.workerSrc = \"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/pdf.js\/3.10.111\/pdf.worker.min.js\";\n  \n  \/\/ Function to close the modal\n  function closeModal() {\n    lightBox.style.display = 'none';\n    pdfViewer.innerHTML = '';\n  }\n  \n  viewButton.addEventListener('click', async () => {\n    lightBox.style.display = 'flex';\n    pdfViewer.innerHTML = '';\n    \n    try {\n      const pdf = await pdfjsLib.getDocument(pdfUrl).promise;\n      \n      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {\n        const page = await pdf.getPage(pageNum);\n        \n        \/\/ Calculate scale to fit width (approx 95vw)\n        const containerWidth = window.innerWidth * 0.95;\n        const viewport = page.getViewport({ scale: 1 });\n        const scale = containerWidth \/ viewport.width;\n        const scaledViewport = page.getViewport({ scale });\n        \n        const canvas = document.createElement('canvas');\n        canvas.className = 'pdf-page-canvas';\n        const context = canvas.getContext('2d');\n        canvas.width = scaledViewport.width;\n        canvas.height = scaledViewport.height;\n        \n        await page.render({ canvasContext: context, viewport: scaledViewport }).promise;\n        pdfViewer.appendChild(canvas);\n      }\n    } catch (error) {\n      console.error('Error loading PDF:', error);\n      pdfViewer.innerHTML = '<p style=\"text-align: center; padding: 20px; color: #666;\">Error loading PDF. Please try again.<\/p>';\n    }\n  });\n  \n  \/\/ Close modal when clicking the close button\n  closeButton.addEventListener('click', closeModal);\n  \n  \/\/ Close modal when clicking outside the PDF viewer\n  lightBox.addEventListener('click', (event) => {\n    if (event.target === lightBox) {\n      closeModal();\n    }\n  });\n  \n  \/\/ Prevent clicks inside the PDF viewer from closing the modal\n  pdfViewer.addEventListener('click', (event) => {\n    event.stopPropagation();\n  });\n  \n  \/\/ Close modal when pressing Escape key\n  document.addEventListener('keydown', (event) => {\n    if (event.key === 'Escape' && lightBox.style.display === 'flex') {\n      closeModal();\n    }\n  });\n<\/script>"}},"custom_liquid_8cddab":{"type":"custom_liquid","name":"amazon button","settings":{"custom_liquid":"<style>\n        .label-container {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: flex-start;\n        }\n\n        .custom-label,\n        .worldwide-label {\n            background-color: #589997; \/* Background color of the label *\/\n            border-radius: 5px; \/* Adjust the border radius to control the roundness of the corners *\/\n            padding: 5px 10px; \/* Adjust padding as needed to control the label size and spacing *\/\n            font-size: 14px; \/* Font size of the label text *\/\n            color: #ffffff; \/* Text color of the label *\/\n            display: inline-block; \/* Ensure the label is displayed as a block element *\/\n            margin: 5px; \/* Add some margin between the labels *\/\n            flex-shrink: 0; \/* Prevent labels from shrinking *\/\n        }\n\n        .worldwide-label {\n            background-color: #d38946; \/* Background color of the label *\/\n        }\n\n        @media only screen and (max-width: 600px) {\n            .custom-label,\n            .worldwide-label {\n                width: 100%; \/* Make labels equal width *\/\ntext-alig